/* Bottom Navigation */
#bottom-nav {
position: fixed;
bottom: 0;
left: 50%;
transform: translateX(-50%);
width: 100%;
max-width: 480px;
height: var(--nav-h);
background: rgba(10,11,15,0.95);
backdrop-filter: blur(16px);
-webkit-backdrop-filter: blur(16px);
border-top: 1px solid var(--border);
display: flex;
align-items: stretch;
z-index: 100;
padding-bottom: env(safe-area-inset-bottom);
}

.nav-item {
flex: 1;
display: flex;
flex-direction: column;
align-items: center;
justify-content: center;
gap: 4px;
position: relative;
background: none;
border: none;
cursor: pointer;
color: var(--text-muted);
transition: color var(--transition);
padding: 0 2px;
-webkit-tap-highlight-color: transparent;
}

.nav-item:active {
transform: scale(0.93);
}

.nav-item.active {
color: var(--accent);
}

.nav-item.active .nav-icon {
background: var(--accent-dim);
}

.nav-icon {
width: 32px;
height: 28px;
display: flex;
align-items: center;
justify-content: center;
border-radius: 8px;
transition: background var(--transition);
}

.nav-icon svg {
width: 18px;
height: 18px;
fill: none;
stroke: currentColor;
stroke-width: 1.8;
stroke-linecap: round;
stroke-linejoin: round;
}

.nav-label {
font-size: 0.6rem;
font-weight: 600;
letter-spacing: 0.04em;
text-transform: uppercase;
white-space: nowrap;
}

/* Active indicator dot */
.nav-item.active::after {
content: '';
position: absolute;
top: 6px;
width: 4px;
height: 4px;
border-radius: 50%;
background: var(--accent);
opacity: 0.7;
}
